.model small
.stack 100h

.data

.code
main proc

    ; initialize data segment
    mov ax, @data
    mov ds, ax # first step always

    ; read character
    mov ah, 01h
    int 21h

    ; move input from AL to DL
    mov dl, al

    ; display character
    mov ah, 02h
    int 21h

    ; exit program
    mov ah, 4Ch
    int 21h

main endp
end main